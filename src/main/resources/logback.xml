<configuration>

    <property name="EVENT_LOG_FILE" value="${eventLogFile:-./simulation.log}" />

    <!-- Console -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} %-5level %logger - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Console appender for EVENT_LOGGER: honours ${logLevel:-INFO} threshold -->
    <appender name="EVENT_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>${logLevel:-INFO}</level>
        </filter>
        <encoder>
            <pattern>%d{HH:mm:ss} %-5level %logger - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Event log: accepts DEBUG and above -->
    <appender name="EVENT_FILE" class="ch.qos.logback.core.FileAppender">
        <file>${EVENT_LOG_FILE}</file>
        <append>false</append>
        <encoder>
            <pattern>%msg%n</pattern>
        </encoder>
    </appender>

    <!-- Event logger: set to DEBUG so the file appender receives DEBUG+;
         EVENT_CONSOLE's ThresholdFilter limits console output to ${logLevel:-INFO}+ -->
    <logger name="EVENT_LOGGER" level="DEBUG" additivity="false">
        <appender-ref ref="EVENT_FILE"/>
        <appender-ref ref="EVENT_CONSOLE"/>
    </logger>

    <!-- Root logger -->
    <root level="${logLevel:-INFO}">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>